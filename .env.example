# Переменные окружения InstaReply. Скопируйте в .env.local и заполните реальными значениями.
# Единственная точка чтения этих переменных в коде — src/lib/env.ts.

# Токен центрального Telegram-бота, выданный @BotFather
TELEGRAM_BOT_TOKEN=changeme

# secret_token, который передаётся в Telegram setWebhook и сверяется в заголовке
# X-Telegram-Bot-Api-Secret-Token на входящих запросах — придумайте случайную строку
TELEGRAM_WEBHOOK_SECRET=changeme

# Секрет для подписи JWT сессий Mini App (initData -> httpOnly cookie)
MINIAPP_JWT_SECRET=changeme

# Ключ AES-256-GCM для шифрования секретов тенантов (access_token и т.п.):
# base64-строка, декодирующаяся РОВНО в 32 байта. Сгенерировать: pnpm tsx scripts/gen-key.ts
ENCRYPTION_KEY=changeme

# URL проекта Supabase, например https://xxxxxxxx.supabase.co
SUPABASE_URL=https://your-project.supabase.co

# Secret key проекта Supabase (только сервер, никогда не отдавать клиенту; обходит RLS)
SUPABASE_SECRET_KEY=changeme

# Базовый URL LLM-провайдера (OpenAI-совместимый API), например OpenRouter
LLM_BASE_URL=https://openrouter.ai/api/v1

# API-ключ LLM-провайдера
LLM_API_KEY=changeme

# Модель для классификации сообщений по меткам
LLM_MODEL_CLASSIFY=openai/gpt-4o-mini

# Модель для генерации черновиков ответов
LLM_MODEL_DRAFT=openai/gpt-4o-mini

# Публичный базовый URL задеплоенного приложения (используется в ссылках, webhook-ах, Mini App)
APP_BASE_URL=https://your-project.vercel.app

# Секрет для защиты роутов /api/cron/* (заголовок Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=changeme

# CSV telegram_user_id администраторов, которым шлются алерты/доступна страница ошибок.
# Можно оставить пустым.
ADMIN_TELEGRAM_IDS=

# Суточный лимит POST /api/miniapp/simulator/message на одного tenant.
# Для ручной проверки T-025 удобно временно поставить 3.
SIMULATOR_DAILY_LIMIT=30

# Business Login for Instagram (обязательно): OAuth — единственный способ подключения Instagram.
# INSTAGRAM_APP_ID — ID продукта Instagram (не общий Meta App ID).
INSTAGRAM_APP_ID=changeme
# INSTAGRAM_APP_SECRET — secret платформенного Meta/Instagram App; используется только на сервере.
INSTAGRAM_APP_SECRET=changeme
# IG_WEBHOOK_VERIFY_TOKEN — verify token глобального webhook /api/wh/ig.
IG_WEBHOOK_VERIFY_TOKEN=changeme
# TELEGRAM_BOT_USERNAME — username бота без @ для ссылки возврата после OAuth.
TELEGRAM_BOT_USERNAME=
