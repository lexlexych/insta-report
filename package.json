{
  "name": "insta-report",
  "version": "0.1.0",
  "private": true,
  "description": "InstaReply — AI-ассистент для ответов клиентам в Instagram Direct через Telegram",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "db:push": "supabase db push",
    "db:types": "supabase gen types typescript --linked > src/lib/db/types.gen.ts",
    "gen:key": "tsx scripts/gen-key.ts",
    "setup:telegram": "tsx scripts/setup-telegram.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.47.10",
    "next": "^15.5.20",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^3.25.76",
    "grammy": "^1.38.4",
    "@telegram-apps/sdk-react": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^20.19.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.20",
    "eslint-config-prettier": "^10.1.8",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "supabase": "^2.109.0",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3"
  }
}
